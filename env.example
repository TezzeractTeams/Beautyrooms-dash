# Auth (required)
AUTH_SECRET=

# MongoDB — for dashboard data snapshots
# Get free connection string from https://cloud.mongodb.com (M0 free tier)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/beautyrooms
# Dashboard login (required)
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Public URL for OAuth (use ngrok when Meta blocks localhost)
AUTH_URL=https://your-subdomain.ngrok-free.dev/api/auth
# Optional extra hosts for Next.js dev (comma-separated)
# ALLOWED_DEV_ORIGINS=modular-aptitude-lemon.ngrok-free.dev

# Google / GA4
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Server-side token — paste from /api/admin/tokens after connecting Google in Settings
GOOGLE_REFRESH_TOKEN=
GA4_PROPERTY_ID=
GA4_MEASUREMENT_ID=
GOOGLE_ADS_CUSTOMER_ID=

# Meta Ads (Facebook Login + Marketing API)
# In Meta App Dashboard → App Review → Permissions: add "ads_read" (Marketing API)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# Server-side token — paste from /api/admin/tokens after connecting Meta in Settings
META_ACCESS_TOKEN=
# Optional default when user has multiple ad accounts (act_123 or numeric id)
META_AD_ACCOUNT_ID=

# Boulevard Admin API (server-to-server credentials)
BLVD_API_KEY=
BLVD_SECRET_KEY=
BLVD_BUSINESS_ID=
BLVD_LOCATION_ID=
